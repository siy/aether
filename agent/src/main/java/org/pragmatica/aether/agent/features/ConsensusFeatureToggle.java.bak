package org.pragmatica.aether.agent.features;

import org.pragmatica.message.MessageRouter;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import java.util.*;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.CopyOnWriteArrayList;

/**
 * Consensus-backed implementation of FeatureToggle.
 * 
 * This implementation stores feature toggle configurations in the consensus log
 * to ensure consistent feature states across all cluster nodes. Toggle evaluations
 * are performed locally for performance, with configuration changes propagated
 * through the consensus system.
 * 
 * The implementation supports:
 * - Hierarchical feature inheritance
 * - Percentage-based rollouts with consistent hashing
 * - User/node/cluster segmentation
 * - Emergency kill switches
 * - Real-time toggle updates without restarts
 */
public class ConsensusFeatureToggle implements FeatureToggle {
    private static final Logger logger = LoggerFactory.getLogger(ConsensusFeatureToggle.class);
    
    private final MessageRouter messageRouter;
    private final Map<String, ToggleConfig> toggleConfigs;
    private final Map<String, List<ToggleListener>> listeners;
    private volatile boolean emergencyMode;
    
    public ConsensusFeatureToggle(MessageRouter messageRouter) {
        this.messageRouter = messageRouter;
        this.toggleConfigs = new ConcurrentHashMap<>();
        this.listeners = new ConcurrentHashMap<>();
        this.emergencyMode = false;
        
        // Initialize with default configurations for known features
        initializeDefaults();
        
        // Register for consensus state changes
        setupConsensusIntegration();
        
        logger.info("ConsensusFeatureToggle initialized with {} default features", 
                   KnownFeature.values().length);
    }
    
    @Override
    public boolean isEnabled(String featureKey, EvaluationContext context) {
        // Emergency mode disables all features
        if (emergencyMode) {
            logger.debug("Feature '{}' disabled due to emergency mode", featureKey);
            return false;
        }
        
        var config = toggleConfigs.get(featureKey);
        if (config == null) {
            // Check if this is a known feature with default value
            var knownFeature = findKnownFeature(featureKey);
            if (knownFeature.isPresent()) {
                logger.debug("Using default value {} for known feature '{}'", 
                           knownFeature.get().getDefaultValue(), featureKey);
                return knownFeature.get().getDefaultValue();
            }
            
            // Unknown feature defaults to disabled
            logger.debug("Unknown feature '{}' defaults to disabled", featureKey);
            return false;
        }
        
        return evaluateToggle(config, context);
    }
    
    @Override
    public void updateToggle(ToggleConfig config) {
        try {
            var oldConfig = toggleConfigs.get(config.featureKey());
            
            // Store in consensus (this would be implemented with actual consensus commands)
            storeToggleInConsensus(config);
            
            // Update local cache
            toggleConfigs.put(config.featureKey(), config);
            
            // Notify listeners
            notifyListeners(config.featureKey(), oldConfig, config);
            
            logger.info("Updated feature toggle '{}': enabled={}, rollout={}", 
                       config.featureKey(), config.enabled(), 
                       config.rolloutPercentage().map(p -> p + "%").orElse("100%"));
            
        } catch (Exception e) {
            logger.error("Failed to update toggle for feature '{}'", config.featureKey(), e);
            throw new RuntimeException("Toggle update failed", e);
        }
    }
    
    @Override
    public Optional<ToggleConfig> getToggleConfig(String featureKey) {
        return Optional.ofNullable(toggleConfigs.get(featureKey));
    }
    
    @Override
    public Map<String, ToggleConfig> getAllToggles() {
        return Map.copyOf(toggleConfigs);
    }
    
    @Override
    public void removeToggle(String featureKey) {
        try {
            var oldConfig = toggleConfigs.remove(featureKey);
            
            if (oldConfig != null) {
                // Remove from consensus
                removeToggleFromConsensus(featureKey);
                
                // Notify listeners
                notifyListeners(featureKey, oldConfig, null);
                
                logger.info("Removed feature toggle '{}'", featureKey);
            }
            
        } catch (Exception e) {
            logger.error("Failed to remove toggle for feature '{}'", featureKey, e);
            throw new RuntimeException("Toggle removal failed", e);
        }
    }
    
    @Override
    public void addToggleListener(String featureKey, ToggleListener listener) {
        listeners.computeIfAbsent(featureKey, k -> new CopyOnWriteArrayList<>()).add(listener);
        logger.debug("Added toggle listener for feature '{}'", featureKey);
    }
    
    @Override
    public void removeToggleListener(String featureKey, ToggleListener listener) {
        var featureListeners = listeners.get(featureKey);
        if (featureListeners != null) {
            featureListeners.remove(listener);
            if (featureListeners.isEmpty()) {
                listeners.remove(featureKey);
            }
        }
        logger.debug("Removed toggle listener for feature '{}'", featureKey);
    }
    
    @Override
    public void emergencyDisableAll() {
        emergencyMode = true;
        logger.warn("EMERGENCY MODE ACTIVATED - All features disabled");
        
        // Notify all listeners about emergency mode
        notifyEmergencyMode(true);
    }
    
    @Override
    public void restoreFromEmergency() {
        emergencyMode = false;
        logger.info("Emergency mode deactivated - Normal feature toggle operation restored");
        
        // Notify all listeners about emergency mode restoration
        notifyEmergencyMode(false);
    }
    
    @Override
    public boolean isEmergencyMode() {
        return emergencyMode;
    }
    
    /**
     * Evaluates a toggle configuration against the provided context.
     */
    private boolean evaluateToggle(ToggleConfig config, EvaluationContext context) {
        // If explicitly disabled, return false
        if (!config.enabled()) {
            return false;
        }
        
        // Check explicit user inclusion
        if (context.userId().isPresent() && 
            config.enabledUserIds().contains(context.userId().get())) {
            return true;
        }
        
        // Check explicit node inclusion
        if (context.nodeId().isPresent() && 
            config.enabledNodeIds().contains(context.nodeId().get())) {
            return true;
        }
        
        // Check explicit cluster inclusion
        if (context.clusterId().isPresent() && 
            config.enabledClusterIds().contains(context.clusterId().get())) {
            return true;
        }
        
        // Check attribute filters
        if (!config.attributeFilters().isEmpty() && matchesAttributeFilters(config, context)) {
            return true;
        }
        
        // Check rollout percentage
        if (config.rolloutPercentage().isPresent()) {
            return isInRolloutPercentage(config.featureKey(), context, config.rolloutPercentage().get());
        }
        
        // Default to enabled if no specific rules apply
        return true;
    }
    
    /**
     * Checks if the context matches the attribute filters.
     */
    private boolean matchesAttributeFilters(ToggleConfig config, EvaluationContext context) {
        return config.attributeFilters().entrySet().stream()
            .allMatch(entry -> {
                String expectedValue = entry.getValue();
                String actualValue = context.customAttributes().get(entry.getKey());
                return Objects.equals(expectedValue, actualValue);
            });
    }
    
    /**
     * Determines if a context is within the rollout percentage using consistent hashing.
     */
    private boolean isInRolloutPercentage(String featureKey, EvaluationContext context, double percentage) {
        // Create a consistent hash based on feature key and context
        String hashInput = featureKey + ":" + 
            context.userId().orElse("") + ":" +
            context.nodeId().orElse("") + ":" +
            context.clusterId().orElse("");
        
        int hash = Math.abs(hashInput.hashCode());
        double normalizedHash = (hash % 10000) / 100.0; // Convert to 0-100 range
        
        boolean inRollout = normalizedHash < percentage;
        logger.trace("Rollout evaluation for '{}': hash={}, percentage={}, included={}", 
                    featureKey, normalizedHash, percentage, inRollout);
        
        return inRollout;
    }
    
    /**
     * Finds a known feature by key.
     */
    private Optional<KnownFeature> findKnownFeature(String featureKey) {
        return Arrays.stream(KnownFeature.values())
            .filter(feature -> feature.getKey().equals(featureKey))
            .findFirst();
    }
    
    /**
     * Initializes default configurations for known features.
     */
    private void initializeDefaults() {
        for (var feature : KnownFeature.values()) {
            var config = ToggleConfig.builder(feature.getKey())
                .enabled(feature.getDefaultValue())
                .description(feature.getDescription())
                .build();
            
            toggleConfigs.put(feature.getKey(), config);
        }
    }
    
    /**
     * Sets up integration with the consensus system.
     * In a real implementation, this would register message handlers for
     * consensus state changes related to feature toggles.
     */
    private void setupConsensusIntegration() {
        // TODO: Register message handlers for:
        // - FeatureToggleUpdateCommand
        // - FeatureToggleRemoveCommand  
        // - FeatureToggleStateSnapshot
        
        logger.debug("Consensus integration set up for feature toggles");
    }
    
    /**
     * Stores a toggle configuration in consensus.
     * In a real implementation, this would create a consensus command.
     */
    private void storeToggleInConsensus(ToggleConfig config) {
        // TODO: Create and send FeatureToggleUpdateCommand through MessageRouter
        logger.debug("Storing toggle '{}' in consensus", config.featureKey());
    }
    
    /**
     * Removes a toggle from consensus.
     * In a real implementation, this would create a consensus command.
     */
    private void removeToggleFromConsensus(String featureKey) {
        // TODO: Create and send FeatureToggleRemoveCommand through MessageRouter
        logger.debug("Removing toggle '{}' from consensus", featureKey);
    }
    
    /**
     * Notifies listeners of toggle changes.
     */
    private void notifyListeners(String featureKey, ToggleConfig oldConfig, ToggleConfig newConfig) {
        // Notify feature-specific listeners
        var featureListeners = listeners.get(featureKey);
        if (featureListeners != null) {
            for (var listener : featureListeners) {
                try {
                    listener.onToggleChanged(featureKey, oldConfig, newConfig);
                } catch (Exception e) {
                    logger.warn("Error notifying toggle listener for feature '{}'", featureKey, e);
                }
            }
        }
        
        // Notify wildcard listeners
        var wildcardListeners = listeners.get("*");
        if (wildcardListeners != null) {
            for (var listener : wildcardListeners) {
                try {
                    listener.onToggleChanged(featureKey, oldConfig, newConfig);
                } catch (Exception e) {
                    logger.warn("Error notifying wildcard toggle listener for feature '{}'", featureKey, e);
                }
            }
        }
    }
    
    /**
     * Notifies listeners about emergency mode changes.
     */
    private void notifyEmergencyMode(boolean emergencyActive) {
        // For emergency mode, we notify about all features being affected
        for (var entry : toggleConfigs.entrySet()) {
            var featureKey = entry.getKey();
            var config = entry.getValue();
            
            // In emergency mode, effective state is disabled regardless of config
            var effectiveOldConfig = emergencyActive ? config : null;
            var effectiveNewConfig = emergencyActive ? null : config;
            
            notifyListeners(featureKey, effectiveOldConfig, effectiveNewConfig);
        }
    }
    
    /**
     * Provides summary information about current toggle states.
     */
    public ToggleSummary getSummary() {
        int totalFeatures = toggleConfigs.size();
        long enabledFeatures = toggleConfigs.values().stream()
            .mapToLong(config -> config.enabled() ? 1 : 0)
            .sum();
        
        long rolloutFeatures = toggleConfigs.values().stream()
            .mapToLong(config -> config.rolloutPercentage().isPresent() ? 1 : 0)
            .sum();
        
        return new ToggleSummary(
            totalFeatures,
            (int) enabledFeatures,
            (int) rolloutFeatures,
            emergencyMode,
            listeners.size()
        );
    }
    
    /**
     * Summary of feature toggle state for monitoring.
     */
    public record ToggleSummary(
        int totalFeatures,
        int enabledFeatures,
        int rolloutFeatures,
        boolean emergencyMode,
        int listenerCount
    ) {}
}