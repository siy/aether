package org.pragmatica.aether.agent.llm;

import org.pragmatica.lang.Result;

import java.time.Duration;
import java.util.List;
import java.util.Map;
import java.util.concurrent.CompletableFuture;

/**
 * Abstraction for Large Language Model providers in the Aether Agent system.
 * 
 * This interface provides a unified way to interact with various LLM providers,
 * including local models (like Qwen3) and cloud-based services. The design
 * supports the hybrid LLM strategy where local models serve as primary providers
 * with cloud services for complex escalation scenarios.
 * 
 * All implementations should be thread-safe and support concurrent requests.
 * The provider abstraction enables testing with mock implementations while
 * supporting production deployment with real LLM services.
 */
public interface LLMProvider {
    
    /**
     * Represents a chat message with role and content.
     */
    record ChatMessage(
        String role,
        String content,
        Map<String, Object> metadata
    ) {
        public ChatMessage(String role, String content) {
            this(role, content, Map.of());
        }
        
        public static ChatMessage system(String content) {
            return new ChatMessage("system", content);
        }
        
        public static ChatMessage user(String content) {
            return new ChatMessage("user", content);
        }
        
        public static ChatMessage assistant(String content) {
            return new ChatMessage("assistant", content);
        }
    }
    
    /**
     * Configuration for LLM completion requests.
     */
    record CompletionRequest(
        List<ChatMessage> messages,
        int maxTokens,
        double temperature,
        double topP,
        List<String> stopSequences,
        Map<String, Object> providerSpecificOptions
    ) {
        
        public static Builder builder() {
            return new Builder();
        }
        
        public static class Builder {
            private List<ChatMessage> messages = List.of();
            private int maxTokens = 1000;
            private double temperature = 0.7;
            private double topP = 0.9;
            private List<String> stopSequences = List.of();
            private Map<String, Object> providerSpecificOptions = Map.of();
            
            public Builder messages(List<ChatMessage> messages) {
                this.messages = messages;
                return this;
            }
            
            public Builder addMessage(ChatMessage message) {
                this.messages = new java.util.ArrayList<>(this.messages);
                this.messages.add(message);
                this.messages = List.copyOf(this.messages);
                return this;
            }
            
            public Builder maxTokens(int maxTokens) {
                this.maxTokens = maxTokens;
                return this;
            }
            
            public Builder temperature(double temperature) {
                this.temperature = temperature;
                return this;
            }
            
            public Builder topP(double topP) {
                this.topP = topP;
                return this;
            }
            
            public Builder stopSequences(List<String> stopSequences) {
                this.stopSequences = stopSequences;
                return this;
            }
            
            public Builder providerSpecificOptions(Map<String, Object> options) {
                this.providerSpecificOptions = options;
                return this;
            }
            
            public CompletionRequest build() {
                return new CompletionRequest(
                    messages, maxTokens, temperature, topP, 
                    stopSequences, providerSpecificOptions
                );
            }
        }
    }
    
    /**
     * Response from LLM completion with metadata.
     */
    record CompletionResponse(
        String content,
        int tokensUsed,
        Duration responseTime,
        double cost,
        String modelUsed,
        Map<String, Object> metadata
    ) {
        public CompletionResponse(String content, int tokensUsed, Duration responseTime, double cost, String modelUsed) {
            this(content, tokensUsed, responseTime, cost, modelUsed, Map.of());
        }
    }
    
    /**
     * Provider capabilities and characteristics.
     */
    record ProviderCapabilities(
        String name,
        String version,
        int maxTokens,
        List<String> supportedFeatures,
        double costPerToken,
        Duration averageLatency,
        boolean supportsStreaming,
        boolean supportsToolCalls
    ) {}
    
    /**
     * Provider health status.
     */
    enum ProviderStatus {
        HEALTHY,      // Provider is fully operational
        DEGRADED,     // Provider has limited functionality
        UNAVAILABLE,  // Provider is not responding
        DISABLED      // Provider is intentionally disabled
    }
    
    /**
     * Health check result for the provider.
     */
    record ProviderHealth(
        ProviderStatus status,
        String statusMessage,
        Duration lastCheckTime,
        Map<String, Object> healthMetrics
    ) {}
    
    /**
     * Generates a text completion using the provider's LLM.
     * 
     * @param request The completion request with messages and configuration
     * @return A future containing the completion result or error
     */
    CompletableFuture<Result<CompletionResponse>> complete(CompletionRequest request);
    
    /**
     * Gets the capabilities of this provider.
     * 
     * @return Provider capabilities including supported features and limits
     */
    ProviderCapabilities getCapabilities();
    
    /**
     * Performs a health check on the provider.
     * 
     * @return A future containing the health check result
     */
    CompletableFuture<ProviderHealth> healthCheck();
    
    /**
     * Gets the unique identifier for this provider.
     * 
     * @return Provider identifier used for routing and selection
     */
    String getProviderId();
    
    /**
     * Checks if the provider supports a specific feature.
     * 
     * @param feature The feature to check for
     * @return true if the feature is supported
     */
    default boolean supportsFeature(String feature) {
        return getCapabilities().supportedFeatures().contains(feature);
    }
    
    /**
     * Estimates the cost for a given request.
     * 
     * @param request The completion request to estimate cost for
     * @return Estimated cost in dollars
     */
    default double estimateCost(CompletionRequest request) {
        var capabilities = getCapabilities();
        int estimatedTokens = request.messages().stream()
            .mapToInt(msg -> msg.content().length() / 4) // Rough token estimation
            .sum() + request.maxTokens();
        return estimatedTokens * capabilities.costPerToken();
    }
}